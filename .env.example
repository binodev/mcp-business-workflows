# Authentication
MCP_API_TOKEN=your-secret-token-here

# Agent test — choose one provider (examples/agent_test.py)
LLM_PROVIDER=google                        # google | anthropic
GOOGLE_API_KEY=your-google-ai-studio-key   # aistudio.google.com (free tier available)
# ANTHROPIC_API_KEY=sk-ant-...             # console.anthropic.com

# GitHub integration
GITHUB_TOKEN=ghp_your_github_token
GITHUB_DEFAULT_REPO=owner/repo

# Webhook targets
WEBHOOK_DEFAULT_URL=https://your-webhook-endpoint.example.com/hook

# Server
MCP_HOST=0.0.0.0
MCP_PORT=8000
MCP_LOG_LEVEL=INFO

# Optional: local storage
NOTES_STORE_PATH=./data/notes.json
